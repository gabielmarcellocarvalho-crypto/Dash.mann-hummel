
# =========================================================
# DASHBOARD MANN HUMMEL - Variaveis de Ambiente
# Copie este arquivo para ".env.local" (dev) e preencha os valores.
# NUNCA commite o arquivo .env / .env.local com valores reais.
# =========================================================


# ---------------------------------------------------------
# META ADS (Facebook Ads + Instagram Ads)
# API: Marketing API (Graph API v19+)
# Onde pegar: https://developers.facebook.com/apps
# ---------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
# Token de acesso de longa duracao (idealmente de um System User no Business Manager)
META_ACCESS_TOKEN=
# ID da conta de anuncios, formato: act_1234567890
META_AD_ACCOUNT_ID=
# ID do Business Manager (opcional, mas recomendado)
META_BUSINESS_ID=


# ---------------------------------------------------------
# INSTAGRAM ORGANICO (Instagram Graph API - conta Business/Creator)
# Usa o MESMO app/token do Meta acima (precisa das permissoes
# instagram_basic, instagram_manage_insights, pages_show_list)
# ---------------------------------------------------------
# ID da conta Instagram Business/Creator conectada a uma Pagina do Facebook
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# ID da Pagina do Facebook vinculada ao perfil do Instagram
INSTAGRAM_LINKED_PAGE_ID=
# Pode reaproveitar o META_ACCESS_TOKEN acima; deixe aqui se usar um token separado
INSTAGRAM_ACCESS_TOKEN=


# ---------------------------------------------------------
# GOOGLE ADS
# API: Google Ads API
# Onde pegar: https://ads.google.com/aw/apicenter (developer token)
#             https://console.cloud.google.com (OAuth client)
# ---------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# ID da conta de anuncios do cliente, formato: 123-456-7890
GOOGLE_ADS_CUSTOMER_ID=
# ID da conta gerenciadora (MCC), se o acesso for via manager account
GOOGLE_ADS_LOGIN_CUSTOMER_ID=


# ---------------------------------------------------------
# AMAZON ADS
# API: Amazon Advertising API
# Onde pegar: https://advertising.amazon.com/API/docs/en-us/get-started/generate-api-tokens
#             (requer app cadastrado via Login with Amazon - LWA)
# STATUS: Amazon reprovou o acesso a API nativa (Advertising API) para esta conta.
# Fonte de dados atual: conector Windsor.ai (ver bloco abaixo), nao a API nativa.
# ---------------------------------------------------------
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
# Profile ID do anunciante (uma conta pode ter varios profiles/marketplaces)
AMAZON_ADS_PROFILE_ID=
# Regiao do endpoint: NA | EU | FE
AMAZON_ADS_REGION=NA

# ---------------------------------------------------------
# AMAZON ADS via WINDSOR.AI (fonte real usada em producao)
# Windsor faz a ponte com a Amazon Advertising API pelo lado deles.
# Onde gerenciar: https://onboarding.windsor.ai
# ---------------------------------------------------------
WINDSOR_API_KEY=
WINDSOR_AMAZON_ADS_ENDPOINT=https://connectors.windsor.ai/amazon_ads


# ---------------------------------------------------------
# MERCADO LIVRE ADS (Product Ads / Mercado Ads API)
# Onde pegar: https://developers.mercadolivre.com.br/devcenter
# ---------------------------------------------------------
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_ACCESS_TOKEN=
MELI_REFRESH_TOKEN=
# URL de redirecionamento configurada no app (fluxo OAuth)
MELI_REDIRECT_URI=
# ID do vendedor/anunciante (user_id do Mercado Livre)
MELI_ADVERTISER_ID=


# ---------------------------------------------------------
# CONFIGURACAO GERAL DA APLICACAO
# ---------------------------------------------------------
NODE_ENV=development
PORT=3000

# Banco de dados (ajustar quando definirmos a stack)
DATABASE_URL=

# Chave para criptografar tokens sensiveis em repouso (gerar com: openssl rand -hex 32)
ENCRYPTION_SECRET=
